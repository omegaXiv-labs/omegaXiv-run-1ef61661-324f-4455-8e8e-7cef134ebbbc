    "smoke_test_command": "SMOKE_DIR=/tmp/ox_smoke_lottery_bias_kit_$(date +%s) && python3 -m venv \"$SMOKE_DIR\" && \"$SMOKE_DIR\"/bin/python -m pip install packages/lottery-bias-kit/dist/omegaxiv_lottery_bias_kit-0.1.0-py3-none-any.whl && \"$SMOKE_DIR\"/bin/python -c \"from lottery_bias_kit import LotteryBiasAnalyzer; print(LotteryBiasAnalyzer.__name__)\""
