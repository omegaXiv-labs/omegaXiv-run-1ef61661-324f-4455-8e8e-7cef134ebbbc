  "extraction_plan": {
    "core_contributions": [
      "Regime segmentation and changepoint-consensus inference under calibrated penalties (H1/C1).",
      "Replication-constrained false-discovery control over descriptor prefixes with isotonic fallback handling (H2/C2).",
      "Bounded-confounding sign identification with theorem-aligned mismatch diagnostics (H3/C3).",
      "Staged fused-transfer evaluation with non-inferiority/superiority gates and transport diagnostics (H4/C4).",
      "Reliability-constrained max-min recalibration and conic-impossibility diagnostics for integrated ranking (H5/C5)."
    ],
    "source_symbols": [
      {
        "source_path": "experiments/EXP_P4_end_to_end_integrated_pipeline/src/lottery_validation/analysis.py",
        "symbols": [
